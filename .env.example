# ─── Aformix Pulse Environment Template ──────────────────────────────────────────
# Copy this file to .env at the root of the repository before running Docker Compose.

# Server Configuration
NODE_ENV=production
PORT=5000

# Frontend URL (for CORS validation)
FRONTEND_URL=http://localhost

# Database Connections (Defaults work with docker-compose out of the box)
MONGODB_URI=mongodb://mongo:27017/aformix_pulse
REDIS_URI=redis://redis:6379

# Security Secrets (Must be changed in production)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production

# Authentication Providers
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
